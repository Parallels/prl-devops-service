{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Devops Service",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/src/main.go",
      // Comment out if you do not need to setup environment variables for the module
      "envFile": "${workspaceFolder}/.env.${input:environment_file}",
      "args": []
    },
    {
      "name": "Debug in Container",
      "type": "go",
      "request": "attach",
      "mode": "remote",
      "remotePath": "",
      "port": 40000,
      "host": "127.0.0.1",
      "showLog": true,
      "apiVersion": 2,
      "trace": "log",
      "logOutput": "rpc",
    },
    {
      "name": "Api Documentation Generator",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/src/api_documentation",
      "envFile": "${workspaceFolder}/.env",
    },
  ],
  "inputs": [
    {
      "id": "environment_file",
      "type": "pickString",
      "options": [
        "all",
        "orchestrator",
        "host",
        "catalog"
      ],
      "default": "all",
      "description": "Select the mode to debug"
    },
    {
      "id": "catalog_command",
      "type": "pickString",
      "options": [
        "run",
        "push",
        "pull",
        "import",
        "list"
      ],
      "default": "run",
      "description": "Select the catalog command to debug"
    },
    {
      "id": "catalog_pdfile",
      "type": "promptString",
      "default": "${workspaceFolder}/out/binaries/test.local.pdfile",
      "description": "Enter the path to the pdfile"
    }
  ]
}