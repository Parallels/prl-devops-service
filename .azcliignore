# Exclude files/dirs from az aks command invoke --file .
# Reduces upload size from 305MB to ~296KB
# Only helm/ and top-level config files are uploaded to the temporary pod
# Reference: https://learn.microsoft.com/en-us/cli/azure/aks/command?view=azure-cli-latest#az-aks-command-invoke
.git
.azcliignore
src
docs
loadtest
scripts
badges
.github
.vscode
.claude
.claude-flow